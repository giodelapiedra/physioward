PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────
# Local database running on your machine
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nookal
# Optional connection pool tuning
DB_POOL_MAX=10
DB_POOL_IDLE_MS=30000

# ── Nookal v2 REST (appointments, patients, inventory) ──────
NOOKAL_API_KEY=your_nookal_v2_api_key_here
NOOKAL_BASE_URL=https://api.nookal.com/production/v2

NOOKAL_LOCATION_NEWPORT=your_newport_location_id
NOOKAL_LOCATION_NARRABEEN=your_narrabeen_location_id
NOOKAL_LOCATION_BROOKVALE=your_brookvale_location_id

# ── Nookal v3 GraphQL (revenue report) ──────────────────────
# CLIENT_SECRET is the "Basic Key" field from Nookal → Setup → Connections
# → GraphQL. It is passed verbatim as `Authorization: Basic <value>`.
NOOKAL_V3_BASE_URL=https://au-apiv3.nookal.com
NOOKAL_V3_CLIENT_ID=your_v3_client_id
NOOKAL_V3_CLIENT_SECRET=your_v3_basic_key

# Real Nookal location IDs (integers) — defaults match our AU account.
NOOKAL_V3_LOCATION_NEWPORT=1
NOOKAL_V3_LOCATION_NARRABEEN=2
NOOKAL_V3_LOCATION_BROOKVALE=6

# ── Auth — CEO login credentials ─────────────────────────────
# Used only to seed the initial CEO user on first boot.
# After seeding, the password is stored bcrypt-hashed in the DB.
CEO_EMAIL=sam@physioward.com.au
CEO_PASSWORD=ChangeMe123!

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=your_minimum_32_char_secret_here
JWT_EXPIRES_IN=15m

# ── Caching ──────────────────────────────────────────────────
# How long a dashboard snapshot is considered fresh (minutes)
SNAPSHOT_TTL_MINUTES=60
