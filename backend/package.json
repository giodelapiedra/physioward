{
  "name": "physioward-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\"",
    "start": "node dist/index.js",
    "db:migrate": "ts-node-dev --transpile-only src/db/migrate.ts",
    "db:seed": "ts-node-dev --transpile-only src/db/seed.ts",
    "db:seed:front-desk": "ts-node-dev --transpile-only src/db/seed-front-desk.ts",
    "db:seed:adspend": "ts-node-dev --transpile-only src/db/seed-adspend.ts",
    "token:google-ads": "ts-node-dev --transpile-only src/scripts/get-google-ads-token.ts",
    "token:google-sheets": "ts-node-dev --transpile-only src/scripts/get-google-sheets-token.ts",
    "db:import:dropouts": "ts-node-dev --transpile-only src/db/import-dropouts-2026.ts",
    "db:import:case-acceptance": "ts-node-dev --transpile-only src/db/import-case-acceptance.ts",
    "db:import:dropouts:gsheets": "ts-node-dev --transpile-only src/db/import-dropouts-gsheets.ts",
    "db:import:case-acceptance:gsheets": "ts-node-dev --transpile-only src/db/import-case-acceptance-gsheets.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-ads-api": "^23.0.0",
    "googleapis": "^173.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
